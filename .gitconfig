# ┌──────────────────────────────────────────────────────────────────────────────────────┐
# │ Diff configuration for: https://github.com/dandavison/delta
[interactive]
  diffFilter = delta --color-only
[merge]
  conflictStyle = zdiff3
[core]
  pager = delta
[delta]
  navigate = true
  line-numbers = true
  hyperlinks = true
  hyperlinks-file-link-format = "vscode://file/{path}:{line}"
  pager = cat
[diff]
  # https://dandavison.github.io/delta/color-moved-support.html
  colorMoved = default # Add color for moved files
	context = 10

  # Use a different theme:
  # features = "collared-trogon"
  # features = "colibri"
  # features = "collared-trogon"
  # features = "coracias-caudatus"
  # features = "hoopoe"
  # features = "tangara-chilensis"
  # features = "villsau"
  # features = "woolly-mammoth"
  # features = "calochortus-lyallii"
  # features = "mantis-shrimp"
  # features = "mantis-shrimp-lite"
  # features = "zebra-dark"
  # features = "zebra-light"
  # features = "chameleon"
  # features = "gruvmax-fang"
  # features = "discord"
  # features = "mellow-barbet"
  # features = "arctic-fox"
  # features = "corvus"
  # features = "platypus"
  # features = "weeping-willow"
  # features = "mirthful-willow"

  # Configure this with the `toggle-ss` alias:
  # side-by-side = true
[include]
  path = /Users/greg/scripts/themes.gitconfig
# └──────────────────────────────────────────────────────────────────────────────────────┘

[user]
    name = Greg Tatum
    email = tatum.creative@gmail.com
[core]
  excludesfile = ~/scripts/.gitignore_global
  editor = vim
  # pager = diff-so-fancy
  fsmonitor = true
  untrackedcache = true
[push]
  default = simple
[alias]
  files = show --name-only
  stat = show --stat
  pop = "!f() { \
    fmt='%C(always,yellow)%h %C(always,red)%ad %C(always,magenta)%an%C(always,green)%d %C(always,reset)%s'; \
    printf 'popped: '; \
    git log -1 --color=always --pretty=format:\"$fmt\" --date=short; \
    git reset --keep HEAD^ || exit $?; \
    printf 'now at:  '; \
    git log -1 --color=always --pretty=format:\"$fmt\" --date=short; \
    printf '\n'; \
  }; f"
  pops = "!f() { \
    fmt='%C(always,yellow)%h %C(always,red)%ad %C(always,magenta)%an%C(always,green)%d %C(always,reset)%s'; \
    printf 'popped: '; \
    git log -1 --color=always --pretty=format:\"$fmt\" --date=short; \
    git reset --soft HEAD^ || exit $?; \
    printf 'now at: '; \
    git log -1 --color=always --pretty=format:\"$fmt\" --date=short; \
    printf '\n'; \
  }; f"
  detach = switch --detach
  wip = log --graph --pretty=oneline --abbrev-commit
  br = !git --no-pager branch --sort='committerdate' --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
  ltst = branch --sort=committerdate
  unstage = restore --staged
  # co = checkout
  re = restore
  sw = switch
  chp = cherry-pick
  checkout = !sh -c 'echo "Use git switch"'
  r = remote -vv
  ls = log --graph --abbrev-commit --decorate --all --date=short --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%ad%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
  # oneline = log --pretty=oneline -n 20 --first-parent
  oneline = log --pretty=format:'%C(yellow)%h %C(red)%ad %C(magenta)%an%C(green)%d %C(reset)%s' --date=short -n 30 --first-parent
  me = !"git ls --author 'Greg Tatum'"
  pr = "!f() { git fetch -fu ${2:-origin} refs/pull/$1/head:pr/$1 && git checkout pr/$1; }; f"
  pr-clean = "!git for-each-ref refs/heads/pr/* --format='%(refname)' | while read ref ; do branch=${ref#refs/heads/} ; git branch -D $branch ; done"
  fp = !sh -c 'git pull --ff -q "$0" "$1" && git fetch -q "$0"'
  rfp = !sh -c 'git checkout "$1" && git fp "$0" "$1" && git co - && git rebase -i "$1"'
  revlog = !sh -c "unbuffer git reflog $@ --pretty=format:'%C(yellow)%h %C(red)%ad %C(magenta)%an%C(green)%d %C(reset)%s' | tac"
  changedate = "!d=\"$(gdate -d \"$1\")\" && shift && GIT_COMMITTER_DATE=\"$d\" \
    git commit --amend --no-edit --date \"$d\""
  up = "!f() { git checkout main && git pull --ff-only && git checkout -; }; f"
  reup = "!f() { git fetch origin main:main && git rebase main; }; f"
  now = !"git commit --amend --date=\"$(date)\" --no-edit"
  find-merge = "!sh -c 'commit=$0 && branch=${1:-HEAD} && (git rev-list $commit..$branch --ancestry-path | cat -n; git rev-list $commit..$branch --first-parent | cat -n) | sort -k2 -s | uniq -f1 -d | sort -n | tail -1 | cut -f2'"
  show-merge = "!sh -c 'merge=$(git find-merge $0 $1) && [ -n \"$merge\" ] && git show $merge'"
  # # touched = !git rev-list --all -- \"$1\" | xargs git log --format='%C(yellow)%h%C(reset) %C(red)%ad%C(reset) %C(magenta)%an%C(reset) %C(green)%d%C(reset) %C(gray)%s%C(reset)' --date=short
  # touched  = "!f() { git rev-list --all --no-merges -- "$1" | tac | xargs git oneline -n 500; }; f"
  # touched2 = "!f() { git rev-list --all --no-merges -- "$1" | tac | xargs git oneline -n 500 -p "$1"; }; f"
  # itouched = "!f() { git rev-list --all --no-merges --author='Greg Tatum' -- "$1" | xargs unbuffer git oneline -n 500 | tac; }; f"
[color]
  ui = true
[gist]
  username = gregtatum
[diff-so-fancy]
  #stripLeadingSymbols = false
  #markEmptyLines = false
  #changeHunkIndicators = false
  ##useUnicodeRuler = false
[commit]
  gpgsign = false
[gpg]
  program = gpg
[absorb]
  maxStack=50
[init]
  defaultBranch = main
[advice]
  detachedHead = false
[gc]
  pruneexpire = "180 days"
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[rebase]
	autosquash = true
